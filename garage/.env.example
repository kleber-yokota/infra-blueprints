# Garage-S3 Service Configuration

# Internal Garage tokens (RPC, admin, metrics)
GARAGE_RPC_SECRET=CHANGE_ME_generate_a_rpc_secret_here
GARAGE_ADMIN_TOKEN=CHANGE_ME_generate_an_admin_token_here
GARAGE_METRICS_TOKEN=CHANGE_ME_generate_a_metrics_token_here

# Garage UI Authentication
GARAGE_UI_AUTH_ADMIN_PASSWORD=CHANGE_ME_generate_a_strong_password_here
GARAGE_UI_AUTH_OIDC_CLIENT_SECRET=CHANGE_ME_generate_a_oidc_client_secret_here

# Garage S3 Access Keys (used by ClickHouse and other services)
# Generate with: docker exec garaged garage key create <key-name>
GARAGE_S3_ACCESS_KEY=CHANGE_ME_generate_s3_access_key
GARAGE_S3_SECRET_KEY=CHANGE_ME_generate_s3_secret_key
